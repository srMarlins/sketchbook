// Sketchbook Firestore Security Rules
//
// Data model lives under /users/{uid}/** — one tenant per Firebase Auth UID. Per the
// migration design (docs/plans/2026-05-08-firebase-migration-design.md "Data model"):
//
//   /users/{uid}
//       /trees/{treeId}              one doc per registered tree (Project, UserLibrary, ...)
//           /journal/{eventId}       append-only audit log
//       /machines/{hostId}           host roster
//       /plugins/{hostId}            per-host plugin slice
//       /locks/{treeId}              tree lease docs (Phase 3)
//
// v1 ships with the strict owner-uid pattern below. v1.2 multi-user adds collaborator
// access on tree docs; the scaffold is included but disabled (`if false`) so the rule
// is visible in the codebase without granting any actual access.
//
// Tests live in tests/firestore-rules/ (see security-commitment #4 — added in Phase 3
// before listener code ships). CI fails the build on rule regression.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------------------
    // helpers
    // -----------------------------------------------------------------------------------

    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // The tree-doc owner_user_id field must equal the path's {uid}. Prevents a client
    // from creating a tree in their namespace that claims to be owned by someone else
    // (which would matter once collaborator-aware rules ship in v1.2).
    function ownerFieldMatchesPath(uid, data) {
      return data.owner_user_id == uid;
    }

    // Reasonable upper bound for any Firestore doc we expect to write today.
    // Trees are <1 KB; machines/plugins <20 KB; journal entries <5 KB.
    // 256 KB leaves headroom for collaborators arrays at v1.2 scale; far below
    // Firestore's 1 MB per-doc hard limit. Cheap guardrail against accidental
    // bloat or malicious oversized writes.
    function withinSizeLimit() {
      return request.resource.size < 256 * 1024;
    }

    // -----------------------------------------------------------------------------------
    // /users/{uid} — user profile root
    // -----------------------------------------------------------------------------------

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && withinSizeLimit();
      // No deletes from clients — account deletion is operator-driven via Cloud
      // Functions (Phase 6+) so we can guarantee blob cleanup, audit-log writes, etc.
      allow delete: if false;

      // -------------------------------------------------------------------------------
      // /users/{uid}/trees/{treeId} — registered tree (Project, UserLibrary, ...)
      // -------------------------------------------------------------------------------

      match /trees/{treeId} {
        // v1: only the owner. v1.2 will add collaborator reads (see commented block below).
        allow read: if isOwner(uid);

        // Writes must (a) be by the owner, (b) claim the owner correctly in the doc body.
        allow create, update: if isOwner(uid)
                              && ownerFieldMatchesPath(uid, request.resource.data)
                              && withinSizeLimit();
        // Tree deletion: owner only. Cascade of subcollections (/journal) is the
        // client's responsibility — Firestore doesn't cascade subcollection docs on
        // parent delete. Phase 3+ may move this to a Cloud Function trigger.
        allow delete: if isOwner(uid);

        // ---------------------------------------------------------------------------
        // /users/{uid}/trees/{treeId}/journal/{eventId} — append-only audit log
        // ---------------------------------------------------------------------------

        match /journal/{eventId} {
          allow read: if isOwner(uid);
          // Append-only: clients can create new entries but never update or delete.
          // Mutation invalidates the audit trail; if we ever need to rewrite history,
          // it goes through a Cloud Function with admin creds, not the client.
          allow create: if isOwner(uid) && withinSizeLimit();
          allow update, delete: if false;
        }
      }

      // -------------------------------------------------------------------------------
      // /users/{uid}/machines/{hostId} — host roster
      // -------------------------------------------------------------------------------

      match /machines/{hostId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid) && withinSizeLimit();
      }

      // -------------------------------------------------------------------------------
      // /users/{uid}/plugins/{hostId} — per-host plugin slice
      // -------------------------------------------------------------------------------

      match /plugins/{hostId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid) && withinSizeLimit();
      }

      // -------------------------------------------------------------------------------
      // /users/{uid}/locks/{treeId} — tree lease (test-and-set via transactions)
      // -------------------------------------------------------------------------------

      match /locks/{treeId} {
        allow read: if isOwner(uid);
        // Owner can create or refresh (update) a lock. Delete is allowed so the
        // current holder can release their own lease. Stale-lease takeover is a
        // tx-level concern; rules just gate by ownership.
        //
        // hasOnly enforces the canonical LockDoc wire shape (snake_case, post-D3).
        // Future field additions must update this whitelist. Empty/absent values
        // for the optional `holder_name` are accepted via the `hasAny` check.
        allow create, update: if isOwner(uid)
                              && withinSizeLimit()
                              && request.resource.data.keys()
                                   .hasOnly(['holder', 'holder_name', 'acquired_at', 'expires_at'])
                              && request.resource.data.keys()
                                   .hasAll(['holder', 'acquired_at', 'expires_at']);
        allow delete: if isOwner(uid);
      }
    }

    // -----------------------------------------------------------------------------------
    // v1.2 multi-user collaborator scaffold (DISABLED — `if false` until ready).
    //
    // When collaborator support lands, replace these `allow ...: if false;` with the
    // active checks. Keeping the scaffold visible documents the model and ensures
    // anyone reading the rules knows it exists.
    //
    // The relevant data is a `collaborators: array<map<{uid, role}>>` field on each
    // tree doc. Rules helpers below need to handle `get()` to read that field, which
    // costs one Firestore read per evaluation — acceptable for low-volume tree-doc
    // operations, not for the journal subcollection (use claim-encoded auth tokens
    // there if collab journal access becomes a feature).
    // -----------------------------------------------------------------------------------

    // function isCollaborator(ownerUid, treeId) {
    //   let tree = get(/databases/$(database)/documents/users/$(ownerUid)/trees/$(treeId)).data;
    //   return request.auth.uid in tree.collaborators.map(c => c.uid);
    // }
    //
    // function isCollaboratorWithWrite(ownerUid, treeId) {
    //   let tree = get(/databases/$(database)/documents/users/$(ownerUid)/trees/$(treeId)).data;
    //   return tree.collaborators.where(c => c.uid == request.auth.uid && c.role in ['write', 'admin']).size() > 0;
    // }

    // -----------------------------------------------------------------------------------
    // Default deny — anything not matched above is rejected. Firestore's default is
    // already deny but stating it explicitly documents intent.
    // -----------------------------------------------------------------------------------

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
