# Tauri's dev watcher rebuilds the app when files under src-tauri/ change.
# The bundled python tree writes .pyc files at import time, which would
# otherwise trigger spurious rebuilds. We can't blanket-ignore binaries/
# because the production bundler reads externalBin and bundle.resources
# from there — so target only the noisy bytecode caches.
binaries/_cache/
binaries/python/Lib/__pycache__/
binaries/python/Lib/**/__pycache__/
binaries/python/Lib/site-packages/**/__pycache__/
binaries/windows-x86_64/python/**/__pycache__/
binaries/macos-arm64/python/**/__pycache__/
binaries/macos-x86_64/python/**/__pycache__/
binaries/linux-x86_64/python/**/__pycache__/
launcher/target/
target/
