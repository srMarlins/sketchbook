# Rust build output
target/

# Runtime data — created by the sidecar at first run when AUDIO_ROOT
# resolves to src-tauri/ (e.g. someone running the launcher directly here).
# The canonical catalog lives at <repo>/data/.
data/

# Sidecar binaries are produced by the build pipeline; do not commit.
# `binaries/python/` and `binaries/dist/` are mirrored next to the
# registered launcher copy by `scripts/build-sidecar.py` for the launcher's
# dev-mode walk-up resolution; they're regenerated, never committed.
binaries/audio-web*
binaries/_cache/
binaries/windows-*/
binaries/macos-*/
binaries/linux-*/
binaries/python/
binaries/dist/

# Launcher build output
launcher/target/

# Tauri-generated icons may be regenerated; the canonical source is icons/source.png
icons/*.png
icons/*.icns
icons/*.ico
!icons/source.png
!icons/.keep
