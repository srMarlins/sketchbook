{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities granted to the main and splash windows.",
  "windows": ["main", "splash"],
  "permissions": [
    "core:default",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "dialog:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "audio-web",
          "sidecar": true,
          "args": ["--port", { "validator": "\\d+" }]
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "audio-web",
          "sidecar": true,
          "args": ["--port", { "validator": "\\d+" }]
        }
      ]
    }
  ]
}
