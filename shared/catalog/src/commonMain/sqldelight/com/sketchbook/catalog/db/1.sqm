-- v1 → v2: add updated_at column to sync_state for the PR-H background drain. Existing rows
-- get 0, which sorts them earliest under selectDirtyOldestFirst — fine, since rows that have
-- never been touched since the upgrade are exactly the ones the drain should process first.
ALTER TABLE sync_state ADD COLUMN updated_at INTEGER NOT NULL DEFAULT 0;

CREATE INDEX idx_sync_state_dirty_updated_at ON sync_state(dirty, updated_at);
