-- v6 → v7: PR-T plugin presence tracking. Adds `is_installed` to project_plugins so the
-- catalog can flag rows whose plugin file is no longer on disk (uninstalled, machine rebuilt,
-- discontinued). Default 1 ("installed") so existing rows don't immediately turn red until the
-- presence probe has actually walked the filesystem at least once — without that, the Home
-- coverage chip would scream on first launch from a partially-migrated catalog.
ALTER TABLE project_plugins ADD COLUMN is_installed INTEGER NOT NULL DEFAULT 1;

CREATE INDEX IF NOT EXISTS idx_pp_is_installed ON project_plugins(is_installed);
