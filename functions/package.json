{
  "name": "sketchbook-functions",
  "description": "Sketchbook Cloud Functions — admin-side hooks the client can't do itself.",
  "private": true,
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
