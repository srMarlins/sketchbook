# python
__pycache__/
*.py[cod]
.venv/
.uv-cache/
*.egg-info/
.pytest_cache/
.ruff_cache/

# project data
data/catalog.db
data/catalog.db-*
data/cache/
data/journal/
data/proposals/

# editors / os
.vscode/
.idea/
Thumbs.db
.DS_Store

# git worktrees (isolated workspaces for parallel development)
.worktrees/

# Claude Code per-user settings
.claude/settings.local.json

# the actual library copy (keep paths only, never commit audio)
Projects/

# local-only test fixtures (real .als files, not committed)
packages/core/tests/fixtures/

# stray JS toolchain output if a tool runs from the repo root instead of web/
node_modules/
.vite/

# scratch debug scripts (one-off investigation tools, never committed).
# `[!_]` after the leading underscore is critical — without it the pattern
# also matches `__init__.py`, silently dropping package init files from
# wheels (hatchling builds from VCS-tracked files only).
_[!_]*.py

# Playwright MCP browser cache
.playwright-mcp/

# project data: logs are reproducible at runtime
data/logs/

# Gradle
.gradle/
build/
**/build/
!gradle-wrapper.jar
out/
local.properties

# Cloud credentials — never commit (Sketchbook GCS service-account keys, etc.)
**/gcp-sa*.json
**/*-sa.json
**/service-account*.json
.gcp/

# Kotlin compiler caches (in-process compiler writes here)
.kotlin/

# Retired frontends — leftover build/cache dirs from the pre-cutover Tauri/web tree.
# The source was deleted in PR-24; these are untracked artifacts that the local
# user can blow away at their leisure.
src-tauri/
web/

